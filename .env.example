# Scroller — environment variables
# Copy to .env.local and fill in values. Never commit secrets.

# ─── Site ────────────────────────────────────────────────────────────────────
# Public-facing base URL. Used by robots.ts, sitemap.ts, metadata, og-image.
NEXT_PUBLIC_SITE_URL=https://scroller-psi.vercel.app

# ─── Supabase (required for /admin, /sites curated section) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://tciqizkiseraumwdzxya.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── MongoDB (required for Amazon source AzDB.MAIN + AmazonDB.topSellers) ────
MONGO_URI=
MONGO_DB=AIDB
# Also accepted (mongo-admin reads any of these):
# MONGO_URL=
# MONGODB_URI=
# MONGODB_DB=

# ─── AWS S3 (required for the images source) ─────────────────────────────────
S3_BUCKET_NAME=com27
S3_REGION=eu-west-2
S3_ACCESS_KEY=
S3_SECRET_ACCESS_KEY=
# Optional prefix to scope the image scan to a sub-folder. Default: "" (root).
# S3_SCROLLER_IMAGE_PREFIX=scroller/

# ─── GitHub (optional, raises GitHub Stars rate limit to 5000/hr) ────────────
GITHUB_TOKEN=

# ─── Amazon Associates (optional, defaults to fs08-21) ───────────────────────
AMAZON_ASSOCIATES_TAG=fs08-21
# Optional: override the source sheet used as a fallback to the Mongo fetcher.
# AMAZON_SHEET_ID=1xSHXo4zF-Lrh2QS2bgvyIubQ2N32dAqnQF_RdXqjk7c
# AMAZON_SHEET_GID=1514657824
